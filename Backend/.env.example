# ─────────────────────────────────────────────────────────────────────────────
# Aurora Backend — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your OWN real values below — NEVER commit the actual .env file.
# ─────────────────────────────────────────────────────────────────────────────

# Flask secret key — used for session signing. Use a long random string.
SECRET_KEY=your-secret-key-here

# JWT secret key — used to sign all JWTs. Use a long random string.
JWT_SECRET_KEY=your-jwt-secret-key-here

# Flask app configuration
FLASK_APP=app.py
FLASK_ENV=development

# Database URL (SQLite for local dev, change for production)
DATABASE_URL=sqlite:///mental_health.db

# Groq API Key — get yours free at https://console.groq.com
# Used to power the Llama 3 conversational AI responses
GROQ_API_KEY=your-groq-api-key-here

# ── Email Notifications (Flask-Mail) ──────────────────────────────────────────
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
